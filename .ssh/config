# Read more about SSH config files: https://linux.die.net/man/5/ssh_config
Host localhost
    User albertoa 
    HostName localhost
    Port 9999
    StrictHostKeychecking no

Host *
    ForwardX11 yes
    ForwardX11Trusted yes
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

Host proxmox_wg
    HostName 10.0.0.1
    User root
    IdentityFile /Users/alberto/.ssh/id_rsa
    SetEnv TERM=xterm-256color

